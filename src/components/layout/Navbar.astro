---
const NAV_LINKS = [
  { href: '/proyectos', label: 'Proyectos' },
  { href: '/servicios', label: 'Servicios' },
  { href: '/sobre-mi', label: 'Sobre mí' },
  { href: '/contacto', label: 'Contacto' },
];

---

<header id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 py-6">
  <div class="container mx-auto px-4 flex justify-between items-center">
    <a href="/" class="flex items-center gap-3 group">
      <div class="w-10 h-10 bg-accent rounded-xl flex items-center justify-center text-bg-deep font-bold text-lg transition-transform duration-500 group-hover:rotate-12">
        IG
      </div>
      <div class="text-xl font-display font-black tracking-tighter text-white">
        IVAN <span class="text-accent group-hover:text-white transition-colors">GONZALEZ</span>
      </div>
    </a>


    <nav class="hidden md:flex items-center gap-8">
      {NAV_LINKS.map(link => (
        <a 
          href={link.href} 
          class="text-xs font-bold uppercase tracking-widest text-text-muted hover:text-accent transition-colors"
        >
          {link.label}
        </a>
      ))}
      <a 
        href="/contacto" 
        class="px-6 py-2 bg-accent/10 border border-accent/20 text-accent rounded-full text-xs font-bold uppercase tracking-widest hover:bg-accent hover:text-bg-deep transition-all"
      >
        Hablemos
      </a>
    </nav>

    <button id="menu-toggle" class="md:hidden text-white p-2 z-[60] relative" aria-label="Menu">
      <div class="w-6 h-5 flex flex-col justify-between relative overflow-hidden group">
        <span class="w-full h-0.5 bg-white transition-all duration-300 origin-left" id="line1"></span>
        <span class="w-full h-0.5 bg-accent transition-all duration-300" id="line2"></span>
        <span class="w-full h-0.5 bg-white transition-all duration-300 origin-left" id="line3"></span>
      </div>
    </button>
  </div>

  <!-- Mobile Menu Overlay -->
  <div id="mobile-menu" class="fixed inset-0 bg-bg-deep/95 backdrop-blur-xl z-[55] flex flex-col items-center justify-center translate-x-full invisible">
    <nav class="flex flex-col items-center gap-8">
      <a 
        href="/" 
        class="mobile-link text-4xl font-display font-black tracking-tighter text-white hover:text-accent transition-colors opacity-0 translate-y-8"
        style="transition-delay: 0ms"
      >
        Inicio
      </a>
      {NAV_LINKS.map((link, i) => (
        <a 
          href={link.href} 
          class="mobile-link text-4xl font-display font-black tracking-tighter text-white hover:text-accent transition-colors opacity-0 translate-y-8"
          style={`transition-delay: ${(i + 1) * 100}ms`}
        >
          {link.label}
        </a>
      ))}
      <a 
        href="/contacto" 
        class="mobile-link px-12 py-4 bg-accent text-bg-deep rounded-xl text-sm font-bold uppercase tracking-[0.2em] opacity-0 translate-y-8"
        style={`transition-delay: ${(NAV_LINKS.length + 1) * 100}ms`}
      >
        Hablemos
      </a>
    </nav>
  </div>
</header>

<script>
  import { gsap } from 'gsap';

  const navbar = document.getElementById('navbar');
  const menuToggle = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');
  const line1 = document.getElementById('line1');
  const line2 = document.getElementById('line2');
  const line3 = document.getElementById('line3');
  
  let isMenuOpen = false;

  // Navbar Scroll Effect
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('bg-bg-deep/80', 'backdrop-blur-md', 'py-4', 'border-b', 'border-white/5');
      navbar?.classList.remove('py-6');
    } else {
      navbar?.classList.remove('bg-bg-deep/80', 'backdrop-blur-md', 'py-4', 'border-b', 'border-white/5');
      navbar?.classList.add('py-6');
    }
  });

  // Mobile Menu Toggle
  menuToggle?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    
    if (isMenuOpen) {
      // Open Menu
      gsap.to(mobileMenu, {
        x: 0,
        autoAlpha: 1,
        duration: 0.6,
        ease: "power4.out"
      });
      
      gsap.to(mobileLinks, {
        y: 0,
        opacity: 1,
        stagger: 0.1,
        duration: 0.8,
        ease: "power3.out",
        delay: 0.3
      });

      // Hamburger to X
      gsap.to(line1, { rotate: 45, y: 1, width: '100%', duration: 0.3 });
      gsap.to(line2, { x: 50, opacity: 0, duration: 0.3 });
      gsap.to(line3, { rotate: -45, y: -1, width: '100%', duration: 0.3 });
      
      document.body.style.overflow = 'hidden';
    } else {
      // Close Menu
      gsap.to(mobileMenu, {
        x: '100%',
        autoAlpha: 0,
        duration: 0.6,
        ease: "power4.in"
      });
      
      gsap.to(mobileLinks, {
        y: 32,
        opacity: 0,
        stagger: 0.05,
        duration: 0.4,
        ease: "power3.in"
      });

      // X to Hamburger
      gsap.to(line1, { rotate: 0, y: 0, width: '100%', duration: 0.3 });
      gsap.to(line2, { x: 0, opacity: 1, duration: 0.3 });
      gsap.to(line3, { rotate: 0, y: 0, width: '100%', duration: 0.3 });
      
      document.body.style.overflow = '';
    }
  });

  // Close menu on link click
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      isMenuOpen = false;
      gsap.to(mobileMenu, { x: '100%', autoAlpha: 0, duration: 0.6 });
      gsap.to(line1, { rotate: 0, y: 0, duration: 0.3 });
      gsap.to(line2, { x: 0, opacity: 1, duration: 0.3 });
      gsap.to(line3, { rotate: 0, y: 0, duration: 0.3 });
      document.body.style.overflow = '';
    });
  });
</script>
