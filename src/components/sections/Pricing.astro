---
const PRICING_PLANS = [
  {
    name: "Web Corporativa / Landing",
    price: "Desde 950€",
    desc: "Presencia digital premium para tu negocio, marca personal o producto. Optimizada al 100% para conversión y posicionamiento orgánico.",
    features: [
      "Diseño a medida (sin plantillas genéricas)",
      "Optimización de velocidad (100/100 Lighthouse)",
      "SEO técnico y estructura semántica completa",
      "Formularios de contacto y analítica integrada",
      "Arquitectura de un solo pago (sin suscripciones)",
      "Soporte post-lanzamiento de 30 días"
    ],
    cta: "Empezar Web",
    highlighted: false
  },
  {
    name: "Aplicación Web / SaaS",
    price: "Desde 2.450€",
    desc: "Desarrollo a medida con lógica de negocio compleja, paneles de administración, bases de datos integradas e interactividad en tiempo real.",
    features: [
      "Dashboard administrativo privado",
      "Integración de APIs y pasarelas de pago",
      "Base de datos robusta y segura (Supabase/PostgreSQL)",
      "Sistema de autenticación y roles de usuario",
      "Panel analítico y automatizaciones de flujos",
      "Soporte y mantenimiento extendido"
    ],
    cta: "Solicitar Desarrollo",
    highlighted: true
  },
  {
    name: "Consultoría / Desarrollo por Horas",
    price: "75€ / hora",
    desc: "Auditorías de código, optimizaciones de velocidad extrema para proyectos existentes o soporte de desarrollo avanzado a demanda.",
    features: [
      "Análisis profundo de rendimiento (Web Vitals)",
      "Auditoría técnica de SEO y buenas prácticas",
      "Migración de stack heredado a moderno (Next.js/Astro)",
      "Configuración de CI/CD e infraestructuras Cloud",
      "Resolución de fallos y bugs críticos",
      "Asesoramiento de arquitectura de software"
    ],
    cta: "Hacer Consulta",
    highlighted: false
  }
];
---

<section id="tarifas" class="py-24 border-t border-white/5 relative overflow-hidden">
  <div class="container mx-auto px-4 relative z-10">
    <div class="pricing-header text-center mb-16 opacity-0 translate-y-10">
      <span class="text-accent font-space-mono text-xs uppercase tracking-widest block mb-4">Planes e Inversión</span>
      <h2 class="text-4xl md:text-5xl font-display font-bold inline-block relative text-white">
        Tarifas Transparentes
        <span class="absolute -bottom-3 left-1/2 -translate-x-1/2 w-16 h-1 bg-accent rounded-full"></span>
      </h2>
      <p class="mt-8 text-text-muted max-w-2xl mx-auto text-lg">
        Sin costes ocultos ni sorpresas de última hora. Proyectos de alta gama tecnológica ajustados a objetivos reales.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch">
      {PRICING_PLANS.map((plan) => (
        <div 
          class={`pricing-card-reveal opacity-0 translate-y-6 flex flex-col h-full rounded-2xl p-8 transition-all duration-500 border ${
            plan.highlighted 
              ? 'bg-bg-card/60 border-accent/30 shadow-[0_0_20px_rgba(0,245,212,0.02)] relative' 
              : 'bg-bg-card/20 border-white/5 hover:border-white/10'
          }`}
        >
          
          <div class="mb-8">
            <h3 class="text-lg font-space-mono font-bold uppercase tracking-widest text-text-muted mb-4">
              {plan.name}
            </h3>
            <div class="flex items-baseline gap-1 mb-4 text-white">
              <span class="text-4xl font-display font-black tracking-tight">{plan.price}</span>
            </div>
            <p class="text-sm text-text-muted leading-relaxed min-h-[72px]">
              {plan.desc}
            </p>
          </div>

          <ul class="space-y-4 mb-8 flex-grow">
            {plan.features.map((feat) => (
              <li class="flex items-start gap-3 text-sm text-text-muted">
                <span class="text-accent/60 font-bold">✓</span>
                <span>{feat}</span>
              </li>
            ))}
          </ul>

          <a
            href="/contacto"
            class={`w-full py-4 rounded-xl font-bold uppercase tracking-widest text-center text-xs transition-all duration-300 block ${
              plan.highlighted
                ? 'bg-accent/10 border border-accent/20 text-accent hover:bg-accent hover:text-bg-deep'
                : 'bg-white/5 border border-white/10 text-white hover:bg-white/10'
            }`}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>
  </div>

  <script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    // Header reveal
    gsap.to('.pricing-header', {
      opacity: 1,
      y: 0,
      duration: 1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: '.pricing-header',
        start: 'top 85%',
      }
    });

    // Cards staggered reveal
    gsap.to('.pricing-card-reveal', {
      opacity: 1,
      y: 0,
      duration: 1,
      stagger: 0.15,
      ease: "power3.out",
      scrollTrigger: {
        trigger: '#tarifas .grid',
        start: 'top 80%',
      }
    });
  </script>
</section>
