---
---

<section class="min-h-screen flex items-center justify-center pt-20 overflow-hidden">
  <div class="text-center z-10">
    <h2 id="hero-subtitle" class="text-accent text-[10px] md:text-xs font-space-mono uppercase tracking-[0.3em] mb-12 flex flex-col md:flex-row items-center justify-center gap-y-4 md:gap-x-8 text-center max-w-[320px] md:max-w-none mx-auto opacity-0 translate-y-4">
      <span class="inline-block -mr-[0.3em]">Software Engineer</span>
      <span class="hidden md:inline-block opacity-30 -mr-[0.3em]">/</span>
      <span class="inline-block -mr-[0.3em]">TypeScript • Next.js • React • Astro</span>
    </h2>

    <h1 id="hero-title" class="text-7xl md:text-8xl lg:text-[10rem] font-display font-bold tracking-tighter leading-none mb-10 flex justify-center flex-wrap gap-x-4">
      <span class="inline-block text-white">Iván</span> 
      <span class="inline-block text-accent">González</span>
    </h1>
    
    <p id="hero-description" class="mt-8 text-xl md:text-2xl text-text-muted max-w-2xl mx-auto leading-relaxed opacity-0">
      Construyo webs y apps con <strong class="text-white">Astro, Next.js, React, Kotlin y Gemini AI</strong>. <br />
      Proyectos limpios, bien documentados y entregados en plazo.
    </p>

    <div class="mt-16 flex flex-col sm:flex-row justify-center gap-4 sm:gap-6 px-4">
      <div class="magnetic-wrap">
        <a 
          href="/contacto" 
          class="hero-btn-primary w-full sm:w-auto max-w-[280px] mx-auto sm:mx-0 px-12 py-5 bg-accent text-bg-deep rounded-xl font-bold uppercase tracking-widest text-[10px] transition-colors shadow-[0_0_25px_rgba(15,157,140,0.4)] text-center block opacity-0 scale-90"
        >
          Hablemos de tu idea
        </a>
      </div>
      <div class="magnetic-wrap">
        <a 
          href="/servicios" 
          class="hero-btn-secondary w-full sm:w-auto max-w-[280px] mx-auto sm:mx-0 px-12 py-5 bg-white/5 border border-white/10 text-white rounded-xl font-bold uppercase tracking-widest text-[10px] transition-colors text-center block opacity-0 scale-90"
        >
          Ver Servicios
        </a>
      </div>
    </div>
  </div>

  <script>
    import { gsap } from 'gsap';

    // 1. Prepare Title for animation (Split chars manually for performance)
    const title = document.querySelector('#hero-title');
    if (title) {
      const words = title.querySelectorAll('span');
      words.forEach(word => {
        const chars = word.textContent!.split('');
        word.innerHTML = chars.map(char => `<span class="char inline-block translate-y-8 opacity-0">${char === ' ' ? '&nbsp;' : char}</span>`).join('');
      });
    }

    // 2. Entrance Timeline
    const tl = gsap.timeline({ defaults: { ease: "power3.out" } });

    tl.to('#hero-subtitle', { opacity: 1, y: 0, duration: 1.2 })
      .to('.char', { 
        y: 0, 
        opacity: 1, 
        stagger: 0.02, 
        duration: 1.2,
      }, "-=0.8")
      .to('#hero-description', { opacity: 1, duration: 1.2, y: 0 }, "-=0.8")
      .to('.hero-btn-primary, .hero-btn-secondary', { 
        opacity: 1, 
        scale: 1, 
        stagger: 0.1, 
        duration: 1, 
      }, "-=1");

    // 3. Magnetic Button Effect
    const magneticWraps = document.querySelectorAll('.magnetic-wrap');
    magneticWraps.forEach(wrap => {
      const btn = wrap.querySelector('a');
      wrap.addEventListener('mousemove', (e: any) => {
        const { left, top, width, height } = wrap.getBoundingClientRect();
        const x = e.clientX - (left + width / 2);
        const y = e.clientY - (top + height / 2);
        
        gsap.to(btn, {
          x: x * 0.15,
          y: y * 0.15,
          duration: 0.6,
          ease: "power2.out"
        });
      });

      wrap.addEventListener('mouseleave', () => {
        gsap.to(btn, {
          x: 0,
          y: 0,
          duration: 1,
          ease: "power3.out"
        });
      });
    });
  </script>

  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-20">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7-7v18" />
    </svg>
  </div>
</section>
